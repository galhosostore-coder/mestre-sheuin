# ============================================
# Variáveis de Ambiente - Exemplo
# ============================================
# Copie este arquivo para .env e preencha com seus valores reais
# NUNCA commite o arquivo .env no repositório!

# API Keys - LLMs
GEMINI_API_KEY=sua_chave_gemini_aqui
OPENROUTER_API_KEY=sua_chave_openrouter_aqui

# API Keys - Serviços
ELEVENLABS_API_KEY=sua_chave_elevenlabs_aqui
BRAIP_API_KEY=sua_chave_braip_aqui

# Banco de Dados
DATABASE_URL=postgresql://usuario:senha@host:porta/banco

# Cache e Vector DB
REDIS_URL=redis://host:porta
QDRANT_URL=http://host:porta

# Evolution API
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_API_KEY=sua_chave_evolution_aqui

# Braip Webhook
WEBHOOK_SECRET=seu_segredo_webhook_aqui

# Aplicação
PORT=3000
INSTANCE_NAME=Bot

# SSH (para scripts utilitários)
SSH_HOST=seu_host_ssh_aqui
SSH_PASSWORD=sua_senha_ssh_aqui
